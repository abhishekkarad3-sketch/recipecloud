# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site URL (Required for OAuth callbacks)
# For local development: http://localhost:4028
# For production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:4028

# Gemini API Key (for nutrition analysis)
GEMINI_API_KEY=your_gemini_api_key

# Node Environment (Auto-set by Render, set to 'production' for production builds)
# NODE_ENV=production

# Port (Auto-set by Render, defaults to 3000 for local development)
# PORT=10000
